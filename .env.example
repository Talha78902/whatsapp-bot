# ─── Required ──────────────────────────────────────────────────────────────────

# Secret used to sign JWT access and refresh tokens.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=your-super-secret-key-min-32-chars

# Port the server listens on (local only — Vercel sets this automatically)
PORT=3000

# ─── WhatsApp Business API (set inside the app at /settings/whatsapp) ─────────
# These are saved in the local store after you log in and configure settings.
# You do NOT need to set them here — just fill them in the Settings page after deploy.
#
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=any-random-string-you-choose

# ─── Optional ──────────────────────────────────────────────────────────────────

# Where to store the local JSON data file.
# Defaults to ./data/store.json locally, and /tmp/store.json on Vercel.
# DATA_DIR=/tmp

# Set to "production" on Vercel / Railway (they set this automatically).
NODE_ENV=development
